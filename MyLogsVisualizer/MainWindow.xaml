<Window x:Class="MyLogsVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Viewer" Width="900" Height="600"
        Background="#1e1e1e">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra superior -->
        <!--
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Button Width="140" Height="32" Content="Cargar archivo de log"
                    Click="LoadLog_Click"
                    Background="#0078D4" Foreground="White"/>

            <TextBox x:Name="SearchBox" Width="409" Height="32"
                     Margin="10 0 0 0" 
                     TextChanged="SearchBox_TextChanged"/>
        </StackPanel>-->
        <!-- Barra superior -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Button Width="140" Height="32" Content="Cargar Log"
            ToolTip="Cargar un archivo de log para visualizar"
            Click="LoadLog_Click"
            Background="#0078D4" Foreground="White"/>

            <TextBox x:Name="SearchBox" Width="309" Height="32"
             Margin="10 0 0 0"
             TextChanged="SearchBox_TextChanged"/>


            <ComboBox x:Name="LevelFilter"
              ToolTip="Filtrar por nivel de log"
              Width="130" Height="32"
              Margin="10 0 0 0"
              Background="#252525"
              Foreground="DimGray"
              SelectionChanged="LevelFilter_SelectionChanged">
                <ComboBoxItem Content="Todos" IsSelected="True"/>
                <ComboBoxItem Content="Information"/>
                <ComboBoxItem Content="Warning"/>
                <ComboBoxItem Content="Error"/>
                <ComboBoxItem Content="Debug"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="LogGrid"
          Grid.Row="1"
          AutoGenerateColumns="False"
          Background="#252525"
          Foreground="White"
          RowBackground="#252525"
          AlternatingRowBackground="#252525"
          GridLinesVisibility="None"
          BorderThickness="0"
          IsReadOnly="True"
          RowHeight="NaN">

            <!-- HEADER -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1e1e1e"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1e1e1e"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Height" Value="35"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2a2a2a"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- FILAS -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Height" Value="Auto"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3a3a3a"/>
            </DataGrid.Resources>

            <DataGrid.Columns>


                <DataGridTextColumn Header="Tiempo" Binding="{Binding Timestamp}" Width="170"/>

                <DataGridTemplateColumn Header="Nivel" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="Badge"
                            Padding="6,2"
                            CornerRadius="4"
                            HorizontalAlignment="Left"
                            Background="#333">

                                <TextBlock Text="{Binding Level}"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                            </Border>

                            <DataTemplate.Triggers>

                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                    <Setter TargetName="Badge" Property="Background" Value="#1f3a5f"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter TargetName="Badge" Property="Background" Value="#5f4a1f"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter TargetName="Badge" Property="Background" Value="#5f1f1f"/>
                                </DataTrigger>

                                <!-- DEBUG -->
                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                    <Setter TargetName="Badge" Property="Background" Value="#3a1f5f"/>
                                </DataTrigger>

                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MENSAJE -->
                <!--<DataGridTextColumn Header="Mensaje" Binding="{Binding Message}" Width="*"/>-->
                <DataGridTemplateColumn Header="Mensaje" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Message, Mode=OneWay}"
                     TextWrapping="Wrap"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     IsReadOnly="True"
                     Padding="4,2"
                     FontSize="13"
                     Style="{x:Null}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>