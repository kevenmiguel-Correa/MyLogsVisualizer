        <DataGrid x:Name="LogGrid"
          Grid.Row="1"
          AutoGenerateColumns="False"
          Background="#252525"
          Foreground="White"
          RowBackground="#252525"
          AlternatingRowBackground="#252525"
          GridLinesVisibility="None"
          BorderThickness="0">

            <!-- HEADER -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1e1e1e"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1e1e1e"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Height" Value="35"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2a2a2a"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- FILAS -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.RowStyle>

            <!-- SELECCIÓN -->
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3a3a3a"/>
            </DataGrid.Resources>

            <DataGrid.Columns>

                <!-- FECHA -->
                <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp}" Width="150"/>

                <!-- NIVEL (🔥 ESTILO PRO) -->
                <DataGridTemplateColumn Header="Nivel" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="Badge"
                            Padding="6,2"
                            CornerRadius="4"
                            HorizontalAlignment="Left"
                            Background="#333">

                                <TextBlock Text="{Binding Level}"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                            </Border>

                            <DataTemplate.Triggers>

                                <!-- INFO -->
                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                    <Setter TargetName="Badge" Property="Background" Value="#1f3a5f"/>
                                </DataTrigger>

                                <!-- WARNING -->
                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter TargetName="Badge" Property="Background" Value="#5f4a1f"/>
                                </DataTrigger>

                                <!-- ERROR -->
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter TargetName="Badge" Property="Background" Value="#5f1f1f"/>
                                </DataTrigger>

                                <!-- DEBUG -->
                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                    <Setter TargetName="Badge" Property="Background" Value="#3a1f5f"/>
                                </DataTrigger>

                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MENSAJE -->
                <DataGridTextColumn Header="Mensaje" Binding="{Binding Message}" Width="*"/>

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>